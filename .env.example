# .env.example - Environment Variables Template
# The portfolio content is static (compiled into the app) — no database needed.

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Christos Kerigkas"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# Email — the only backend dependency (contact form notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"
SMTP_FROM="noreply@yourdomain.com"
FROM_EMAIL="noreply@yourdomain.com"
CONTACT_EMAIL="contact@yourdomain.com"
CONTACT_FORM_TO_EMAIL="contact@yourdomain.com"
NOTIFICATION_EMAIL="notifications@yourdomain.com"

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS="100"
RATE_LIMIT_WINDOW_MS="900000" # 15 minutes

# Analytics (Optional)
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_GA_TRACKING_ID="GA_MEASUREMENT_ID"
NEXT_PUBLIC_GOOGLE_ANALYTICS="G-XXXXXXXXXX"

# Sentry Error Tracking (Optional)
NEXT_PUBLIC_SENTRY_DSN="your_sentry_dsn_here"
SENTRY_ORG="your_sentry_organization"
SENTRY_PROJECT="your_sentry_project"
SENTRY_AUTH_TOKEN="your_sentry_auth_token_here"

# Search engine verification (Optional)
GOOGLE_VERIFICATION_ID=""
BING_VERIFICATION_ID=""
YANDEX_VERIFICATION_ID=""

# Social Media (Optional)
NEXT_PUBLIC_TWITTER_HANDLE="@yourhandle"
NEXT_PUBLIC_LINKEDIN_URL="https://linkedin.com/in/yourprofile"
NEXT_PUBLIC_GITHUB_URL="https://github.com/yourusername"

# Feature Flags (Optional)
ENABLE_RATE_LIMITING="true"
ENABLE_OFFLINE_SUPPORT="true"
ENABLE_PERFORMANCE_MONITORING="true"
LOG_LEVEL="info" # debug, info, warn, error

# Development
NODE_ENV="development"
ANALYZE="false" # Set to "true" to analyze bundle size
